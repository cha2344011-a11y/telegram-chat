# ==============================
# BOT 1 CREDENTIALS (e.g., Rahul)
# ==============================
API_ID_1=your_api_id_here
API_HASH_1=your_api_hash_here
PHONE_1=+91XXXXXXXXXX
SESSION_STRING_1=         # Leave blank first time, auto-generated
PERSONALITY_1=bot1

# ==============================
# BOT 2 CREDENTIALS (e.g., Riya)
# ==============================
API_ID_2=your_api_id_here
API_HASH_2=your_api_hash_here
PHONE_2=+91XXXXXXXXXX
SESSION_STRING_2=         # Leave blank first time, auto-generated
PERSONALITY_2=bot2

# ==============================
# AI API KEYS
# ==============================
GEMINI_API_KEY=your_google_gemini_api_key_here

# ==============================
# GROUP / TARGET SETTINGS
# ==============================
# Comma-separated group usernames or IDs to monitor
TARGET_GROUPS=-1001234567890,-1009876543210
# Your own user ID (to receive alerts, get from @userinfobot)
ADMIN_ID=123456789

# ==============================
# BOT BEHAVIOR CONFIG
# ==============================
# How many seconds to wait before replying (simulate reading)
MIN_REPLY_DELAY=8
MAX_REPLY_DELAY=35
# Probability bot replies to any given message (0.0 to 1.0)
REPLY_CHANCE=0.4
# Typing simulation speed (chars per second)
TYPING_SPEED=12
